# Used by docker-compose.yml to provision the dedicated einding_db container
# and build DATABASE_URL for the einding service.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

EINDING_API_TOKEN=change-me-to-a-long-random-string

# Frontend build-time (baked into the static bundle at `docker build` time) --
# must match EINDING_API_TOKEN above.
VITE_API_TOKEN=change-me-to-a-long-random-string

# Only needed for running the Go binary directly (outside docker-compose),
# e.g. local development against a manually-started Postgres.
# DATABASE_URL=postgres://einding:password@localhost:5432/einding?sslmode=disable

# Optional: n8n webhook URLs for on-demand news refresh (the "Webhook -
# Refresh ... News" nodes). Leave a line commented out until that n8n
# workflow's Webhook node exists -- the /api/news/refresh endpoint just
# returns "not configured" for that category until then, nothing else breaks.
N8N_GLOBAL_NEWS_REFRESH_URL=https://n8n.mandalafoods.co/webhook/refresh-global-news
# N8N_NEPALI_NEWS_REFRESH_URL=https://n8n.mandalafoods.co/webhook/refresh-nepali-news
